{
  "name": "claude-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch --import tsx server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "better-sqlite3": "^12.8.0",
    "express": "^5",
    "pino": "^10.3.1",
    "react-window": "^2.2.7",
    "uuid": "^11",
    "ws": "^8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10",
    "@types/ws": "^8",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9",
    "jsdom": "^27.0.1",
    "pino-pretty": "^13.1.3",
    "react": "^19",
    "react-dom": "^19",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3.2.4"
  }
}
