{
  "name": "claude-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "express": "^5",
    "uuid": "^11",
    "ws": "^8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/uuid": "^10",
    "@types/ws": "^8",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9",
    "react": "^19",
    "react-dom": "^19",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^6"
  }
}
